<script>
  // ---- State machine -----------------------------------------------------
  const STATES = {
    AWAIT_YESNO: "awaiting_yes_no",
    AWAIT_DATE:  "awaiting_date",
    AWAIT_TIME:  "awaiting_time",
    DONE:        "done",
    DECLINED:    "declined"
  };

  let state = STATES.AWAIT_YESNO;
  let scheduledDate = null;
  let scheduledTime = null;

  const chat   = document.getElementById("chat");
  const input  = document.getElementById("msgInput");
  const sendBtn = document.getElementById("sendBtn");
  const resetBtn = document.getElementById("resetBtn");

  // ---- Helpers -----------------------------------------------------------
  function timeNow() {
    const d = new Date();
    let h = d.getHours();
    const m = d.getMinutes();
    const ampm = h >= 12 ? "PM" : "AM";
    h = h % 12 || 12;
    return `${h}:${m.toString().padStart(2, "0")} ${ampm}`;
  }

  function scrollDown() {
    requestAnimationFrame(() => { chat.scrollTop = chat.scrollHeight; });
  }

  function addDateDivider(text) {
    const el = document.createElement("div");
    el.className = "date-divider";
    el.textContent = text;
    chat.appendChild(el);
    scrollDown();
  }

  // Render bold (**x** or *x*) and basic newlines
  function renderRich(text) {
    return text
      .replace(/\*\*(.+?)\*\*/g, "<b>$1</b>")
      .replace(/\*(.+?)\*/g, "<b>$1</b>")
      .replace(/\n/g, "<br>");
  }

  function addBotMsg(text) {
    return new Promise(resolve => {
      const typing = document.createElement("div");
      typing.className = "typing";
      typing.innerHTML = '<span class="dot"></span><span class="dot"></span><span class="dot"></span>';
      const row = document.createElement("div");
      row.className = "row bot";
      row.appendChild(typing);
      chat.appendChild(row);
      scrollDown();

      const delay = 700 + Math.min(text.length * 14, 1100);
      setTimeout(() => {
        row.remove();
        const m = document.createElement("div");
        m.className = "msg bot";
        m.innerHTML = renderRich(text)
          + `<span class="meta">${timeNow()}</span>`;
        const r = document.createElement("div");
        r.className = "row bot";
        r.appendChild(m);
        chat.appendChild(r);
        scrollDown();
        resolve();
      }, delay);
    });
  }

  function addUserMsg(text) {
    const m = document.createElement("div");
    m.className = "msg user";
    m.innerHTML = escapeHtml(text)
      + `<span class="meta">${timeNow()}<span class="check">✓✓</span></span>`;
    const r = document.createElement("div");
    r.className = "row user";
    r.appendChild(m);
    chat.appendChild(r);
    scrollDown();
  }

  function escapeHtml(s) {
    return s.replace(/[&<>"']/g, c => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" }[c]));
  }

  // ---- Parsing helpers ---------------------------------------------------
  function looksLikeYes(t) {
    return /^(yes|yeah|yep|yup|y|sure|ok(ay)?|book( it)?|please|pls|go ahead|sounds good)\b/i.test(t.trim());
  }
  function looksLikeNo(t) {
    return /^(no|nope|n|not (now|today)|i'?m fine|i have meds?|got meds?)\b/i.test(t.trim());
  }
  function hasTime(t) {
    return /\b\d{1,2}(:\d{2})?\s*(am|pm)\b/i.test(t)
        || /\b([01]?\d|2[0-3]):[0-5]\d\b/.test(t)
        || /\b(noon|midnight|morning|afternoon|evening)\b/i.test(t);
  }
  function hasDate(t) {
    return /\b\d{1,2}(st|nd|rd|th)?\s*(jan(uary)?|feb(ruary)?|mar(ch)?|apr(il)?|may|jun(e)?|jul(y)?|aug(ust)?|sep(t|tember)?|oct(ober)?|nov(ember)?|dec(ember)?)\b/i.test(t)
        || /\b(today|tomorrow|tmrw|tmr|monday|tuesday|wednesday|thursday|friday|saturday|sunday|next (week|monday|tuesday|wednesday|thursday|friday|saturday|sunday))\b/i.test(t)
        || /\b\d{1,2}[\/\-]\d{1,2}([\/\-]\d{2,4})?\b/.test(t);
  }
  function normalizeDate(raw) {
    // strip trailing year (so "31st May 2026" → "31st May")
    return raw.replace(/[,\s]+\d{4}\s*$/i, "").trim();
  }
  function normalizeTime(raw) {
    const m = raw.match(/(\d{1,2})(?::(\d{2}))?\s*(am|pm)?/i);
    if (!m) return raw.trim();
    let h = parseInt(m[1], 10);
    const min = m[2] || "00";
    let ampm = (m[3] || "").toUpperCase();
    if (!ampm) {
      if (h >= 13) { ampm = "PM"; h -= 12; }
      else if (h === 0) { ampm = "AM"; h = 12; }
      else if (h === 12) { ampm = "PM"; }
      else { ampm = "AM"; }
    }
    if (h === 0) h = 12;
    return `${h}:${min} ${ampm}`;
  }

  // ---- Conversation ------------------------------------------------------
  async function handleSend() {
    const text = input.value.trim();
    if (!text) return;
    addUserMsg(text);
    input.value = "";
    input.focus();
    await new Promise(r => setTimeout(r, 320));
    await routeReply(text);
  }

  async function routeReply(text) {
    if (state === STATES.AWAIT_YESNO) {
      if (looksLikeYes(text)) {
        state = STATES.AWAIT_DATE;
        await addBotMsg(`Great! Please share your preferred date and time — for example: "22nd April, 3pm." 😊`);
      } else if (looksLikeNo(text)) {
        state = STATES.DECLINED;
        await addBotMsg(`No problem — we'll follow up closer to your refill date. If anything changes, just message us. 🙂`);
      } else {
        await addBotMsg(`Just to confirm — would you like to book a callback with your doctor? Reply **YES** to book or **NO** if you're sorted.`);
      }
      return;
    }

    if (state === STATES.AWAIT_DATE) {
      const d = hasDate(text);
      const t = hasTime(text);
      if (d && t) {
        scheduledDate = normalizeDate(text);
        scheduledTime = normalizeTime(text);
        state = STATES.DONE;
        await confirmBooking();
      } else if (d || /\d/.test(text)) {
        scheduledDate = normalizeDate(text);
        state = STATES.AWAIT_TIME;
        await addBotMsg(`Got it — and what time works best for you?`);
      } else {
        await addBotMsg(`Could you share a specific date? For example: *31st May 2026* or *Tomorrow*.`);
      }
      return;
    }

    if (state === STATES.AWAIT_TIME) {
      scheduledTime = normalizeTime(text);
      state = STATES.DONE;
      await confirmBooking();
      return;
    }

    if (state === STATES.DONE) {
      await addBotMsg(`You're all set, Ahmed. If you need anything else, just message us here. 👋`);
      return;
    }
    if (state === STATES.DECLINED) {
      await addBotMsg(`Got it — we're here whenever you need us. Take care! 🙂`);
      return;
    }
  }

  async function confirmBooking() {
    const slot = `${scheduledDate} at ${scheduledTime}`;
    await addBotMsg(
      `Done! Your refill consultation is booked for **${slot}**. Your doctor will call you then. 😊\n\n` +
      `Take care, Ahmed — reach out anytime if you need anything!`
    );
  }

  // ---- Boot --------------------------------------------------------------
  async function startDemo() {
    state = STATES.AWAIT_YESNO;
    scheduledDate = null;
    scheduledTime = null;
    chat.innerHTML = "";
    addDateDivider("Wed, 22 Apr");

    await new Promise(r => setTimeout(r, 600));
    await addBotMsg(
      `Hi **Ahmed**, this is a message from your healthcare team.\n\n` +
      `The following medication refill is coming up:\n` +
      `• **Metformin 500mg**: is due in 3 days (on 25 Apr)\n\n` +
      `Would you like to schedule a callback with your doctor to arrange your refill? Reply **YES** to book or **NO** if you have medication remaining with you.`
    );
    input.focus();
  }

  // Wire up
  sendBtn.addEventListener("click", handleSend);
  input.addEventListener("keydown", e => {
    if (e.key === "Enter") handleSend();
  });
  resetBtn.addEventListener("click", startDemo);

  // Live clock in status bar
  function tickClock() {
    const d = new Date();
    let h = d.getHours();
    const m = d.getMinutes();
    document.getElementById("clock").textContent =
      `${h}:${m.toString().padStart(2, "0")}`;
  }
  tickClock();
  setInterval(tickClock, 30000);

  startDemo();
</script>
</body>
</html>
