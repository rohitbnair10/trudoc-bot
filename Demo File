<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta name="theme-color" content="#0b141a" />
<title>TruDoc Refill Bot — Demo</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  html, body {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", Roboto, sans-serif;
    background: radial-gradient(circle at top, #1a1a1a 0%, #050505 70%);
    color: #e9edef;
    overflow: hidden;
  }

  body {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  /* Phone shell */
  .phone {
    width: 100%;
    max-width: 400px;
    height: min(880px, 96vh);
    background: #0b141a;
    border-radius: 44px;
    border: 10px solid #111;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
  }

  /* Notch */
  .notch {
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 110px;
    height: 28px;
    background: #000;
    border-radius: 0 0 18px 18px;
    z-index: 20;
  }

  /* Status bar */
  .status-bar {
    height: 44px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 28px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
    background: #0b141a;
  }

  .status-icons { display: inline-flex; gap: 5px; align-items: center; }
  .status-icons svg { fill: #fff; }
  .battery { display: inline-flex; align-items: center; gap: 2px; font-size: 11px; }
  .battery-shell {
    width: 22px; height: 11px;
    border: 1px solid #fff; border-radius: 3px;
    padding: 1px; position: relative;
  }
  .battery-shell::after {
    content: ""; position: absolute; right: -3px; top: 3px;
    width: 2px; height: 5px; background: #fff; border-radius: 0 1px 1px 0;
  }
  .battery-fill { height: 100%; width: 65%; background: #fff; border-radius: 1px; }

  /* Chat header */
  .header {
    background: #1f2c33;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
  }

  .back {
    color: #00a884;
    font-size: 24px;
    line-height: 1;
    font-weight: 300;
    padding: 0 4px;
    user-select: none;
  }

  .avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00a884 0%, #008a6e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.5px;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.06);
  }

  .header-meta { display: flex; flex-direction: column; gap: 1px; }
  .header-name { font-size: 16px; font-weight: 500; color: #e9edef; }
  .header-status { font-size: 12px; color: #8696a0; }

  .header-icons { margin-left: auto; display: flex; gap: 18px; color: #aebac1; }
  .header-icons svg { width: 22px; height: 22px; fill: currentColor; }

  /* Chat area */
  .chat {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 12px 8px 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    background-color: #0b141a;
    background-image:
      radial-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      radial-gradient(rgba(255,255,255,0.018) 1px, transparent 1px);
    background-size: 24px 24px, 36px 36px;
    background-position: 0 0, 12px 18px;
    scroll-behavior: smooth;
  }
  .chat::-webkit-scrollbar { width: 0; }

  .date-divider {
    align-self: center;
    background: #1f2c33;
    padding: 5px 12px;
    border-radius: 8px;
    font-size: 12px;
    color: #8696a0;
    margin: 8px 0 6px;
    box-shadow: 0 1px 1px rgba(0,0,0,0.15);
  }

  .row { display: flex; width: 100%; }
  .row.bot { justify-content: flex-start; }
  .row.user { justify-content: flex-end; }

  .msg {
    max-width: 78%;
    padding: 7px 9px 8px 11px;
    border-radius: 8px;
    font-size: 14.5px;
    line-height: 1.42;
    word-wrap: break-word;
    position: relative;
    animation: pop 0.18s ease-out;
    box-shadow: 0 1px 0.5px rgba(0,0,0,0.13);
  }

  @keyframes pop {
    from { opacity: 0; transform: translateY(4px) scale(0.99); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .msg.bot {
    background: #202c33;
    color: #e9edef;
    border-top-left-radius: 0;
  }
  .msg.bot::before {
    content: "";
    position: absolute;
    top: 0;
    left: -8px;
    width: 8px;
    height: 13px;
    background: #202c33;
    clip-path: polygon(100% 0, 0 0, 100% 100%);
  }

  .msg.user {
    background: #005c4b;
    color: #e9edef;
    border-top-right-radius: 0;
  }
  .msg.user::before {
    content: "";
    position: absolute;
    top: 0;
    right: -8px;
    width: 8px;
    height: 13px;
    background: #005c4b;
    clip-path: polygon(0 0, 100% 0, 0 100%);
  }

  .msg .meta {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    float: right;
    margin-left: 8px;
    margin-top: 4px;
    font-size: 11px;
    color: #8696a0;
    line-height: 1;
  }
  .msg.user .meta { color: #aebac1; }
  .check { font-size: 14px; color: #53bdeb; letter-spacing: -3px; }

  .msg b { font-weight: 600; color: inherit; }

  /* Typing indicator */
  .typing {
    background: #202c33;
    padding: 12px 14px;
    border-radius: 8px;
    border-top-left-radius: 0;
    display: inline-flex;
    gap: 4px;
    align-items: center;
    align-self: flex-start;
    box-shadow: 0 1px 0.5px rgba(0,0,0,0.13);
    position: relative;
  }
  .typing::before {
    content: "";
    position: absolute;
    top: 0;
    left: -8px;
    width: 8px;
    height: 13px;
    background: #202c33;
    clip-path: polygon(100% 0, 0 0, 100% 100%);
  }
  .dot {
    width: 7px;
    height: 7px;
    background: #8696a0;
    border-radius: 50%;
    animation: pulse 1.2s infinite ease-in-out;
  }
  .dot:nth-child(2) { animation-delay: 0.18s; }
  .dot:nth-child(3) { animation-delay: 0.36s; }

  @keyframes pulse {
    0%, 60%, 100% { opacity: 0.35; transform: scale(1); }
    30% { opacity: 1; transform: scale(1.15); }
  }

  /* Input bar */
  .input-bar {
    background: #1f2c33;
    padding: 6px 8px 8px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .input-icon, .input-icon-right {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: #8696a0; flex-shrink: 0;
  }
  .input-icon svg, .input-icon-right svg { width: 22px; height: 22px; fill: currentColor; }

  .input-shell {
    flex: 1;
    background: #2a3942;
    border-radius: 24px;
    padding: 8px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 40px;
  }
  .input-field {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: #e9edef;
    font-size: 15px;
    font-family: inherit;
  }
  .input-field::placeholder { color: #8696a0; }
  .input-shell svg { width: 22px; height: 22px; fill: #8696a0; flex-shrink: 0; }

  .send-btn {
    width: 42px; height: 42px;
    background: #00a884;
    border: none; border-radius: 50%;
    color: white; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: transform 0.1s, background 0.1s;
  }
  .send-btn:hover { background: #06cf99; }
  .send-btn:active { transform: scale(0.95); }
  .send-btn svg { width: 20px; height: 20px; fill: #fff; }

  /* Home-indicator-style reset (looks like part of the phone chrome) */
  .reset {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    background: transparent;
    color: rgba(150, 160, 165, 0.35);
    border: none;
    padding: 4px;
    cursor: pointer;
    z-index: 30;
    font-family: inherit;
    transition: color 0.15s, transform 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }
  .reset svg { width: 12px; height: 12px; fill: currentColor; }
  .reset:hover { color: rgba(200, 210, 215, 0.7); }
  .reset:active { transform: translateX(-50%) scale(0.9); }

  /* Footer label outside phone */
  .demo-tag {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.3);
    font-size: 11px;
    letter-spacing: 0.5px;
    pointer-events: none;
  }

  @media (max-width: 420px) {
    body { padding: 0; }
    .phone { border-radius: 0; border: 0; height: 100vh; max-width: 100%; }
    .notch { display: none; }
  }
</style>
</head>
<body>

<div class="phone">
